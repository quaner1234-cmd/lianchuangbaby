---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Custom Baby Sleeping Bag Manufacturer | OEM/ODM | GOTS & BSCI Certified"
  description="Factory-direct custom baby sleeping bag manufacturer. GOTS certified organic cotton, bamboo & merino. TOG 0.5–3.5, OEM/ODM, low MOQ from 100pcs. BSCI audited. Taian Lianchuang Textile."
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-bg-blob blob1"></div>
    <div class="hero-bg-blob blob2"></div>

    <div class="container hero-inner">
      <div class="hero-content animate-fade-up">
        <div class="hero-badges">
          <span class="pill pill-green">🌱 GOTS Certified</span>
          <span class="pill pill-peach">✅ BSCI Audited</span>
        </div>

        <h1>
          Your <em>Custom</em> Baby<br/>
          Sleeping Bag Factory
        </h1>

        <p class="hero-sub">
          OEM & ODM manufacturer specializing in baby sleeping bags — organic cotton, bamboo, and merino wool. Full TOG range (0.5–3.5), custom sizing, prints, and private label. Factory-direct from Shandong, China.
        </p>

        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Request a Sample →</a>
          <a href="#products" class="btn btn-outline">View TOG Range</a>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">100+</span>
            <span class="stat-label">Min. Order (pcs)</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">10–15</span>
            <span class="stat-label">Days Sample Lead Time</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">4</span>
            <span class="stat-label">TOG Ratings Available</span>
          </div>
        </div>
      </div>

      <div class="hero-visual animate-fade-up animate-delay-2">
        <div class="hero-card-main card">
          <div class="product-visual">
            <div class="product-icon">🌙</div>
            <div class="product-glow"></div>
          </div>
          <div class="product-info">
            <div class="label">OEM / ODM Ready</div>
            <h3>Organic Cotton Sleeping Bag</h3>
            <p>TOG 0.5 – 3.5 · Sizes 0–36M · Custom prints & colors</p>
          </div>
          <div class="cert-pills">
            <span class="pill pill-green">GOTS</span>
            <span class="pill pill-peach">BSCI</span>
            <span class="pill pill-cream">EN 16781</span>
          </div>
        </div>

        <div class="hero-float-card float-card-1 card animate-delay-3">
          <div style="font-size:1.6rem;margin-bottom:0.4rem;">🎨</div>
          <strong>Full Custom</strong>
          <p>Colors · Prints · Labels · Packaging</p>
        </div>

        <div class="hero-float-card float-card-2 card">
          <div style="font-size:1.6rem;margin-bottom:0.4rem;">📦</div>
          <strong>Low MOQ</strong>
          <p>From 100 pcs per style</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST BAR ═══ -->
  <section class="trust-bar">
    <div class="container trust-inner">
      <div class="trust-item">🏭 Direct Factory · No Middlemen</div>
      <div class="trust-sep">·</div>
      <div class="trust-item">🌿 GOTS Organic Certified</div>
      <div class="trust-sep">·</div>
      <div class="trust-item">✅ BSCI Social Compliance</div>
      <div class="trust-sep">·</div>
      <div class="trust-item">🛡️ EN 16781 Safety Standard</div>
      <div class="trust-sep">·</div>
      <div class="trust-item">✈️ Worldwide Export · FOB Qingdao</div>
    </div>
  </section>

  <!-- ═══ TOG PRODUCTS ═══ -->
  <section class="section" id="products">
    <div class="container">
      <div class="section-header">
        <div class="label">Product Range</div>
        <h2 class="section-heading">Full TOG Range, <em>Fully Customizable</em></h2>
        <p class="section-sub">Every TOG rating is available in all three fabric options. Custom sizing, colors, prints, and labeling included.</p>
      </div>

      <div class="tog-grid tog-grid-5">
        <a href="/products/premium-muslin-muted-tones" class="tog-card card tog-muted tog-card-featured">
          <div class="tog-season-icon">🌿</div>
          <div class="tog-number" style="font-size:1.6rem;line-height:1.2;">Muted<br/>Tones</div>
          <div class="tog-name">Premium Muslin – Summer Series</div>
          <div class="tog-temp">0.5 TOG · Room temp 24–27°C</div>
          <p class="tog-desc">Sage Green, Terracotta &amp; Sand — the 2026 "Emotional Parenting" palette. Organic muslin, OEKO-TEX certified, OEM/ODM ready.</p>
          <div class="tog-featured-badge">New Launch</div>
          <div class="tog-link">View Full Listing →</div>
        </a>

        <a href="/products/tog-05" class="tog-card card tog-summer">
          <div class="tog-season-icon">☀️</div>
          <div class="tog-number">0.5</div>
          <div class="tog-name">TOG Summer Bag</div>
          <div class="tog-temp">Room temp 24–27°C</div>
          <p class="tog-desc">Lightweight sleeping bag for warm nights. Ideal for travel and summer collections. Breathable organic cotton or bamboo.</p>
          <div class="tog-link">View Details →</div>
        </a>

        <a href="/products/tog-10" class="tog-card card tog-spring">
          <div class="tog-season-icon">🌤️</div>
          <div class="tog-number">1.0</div>
          <div class="tog-name">TOG All-Season Bag</div>
          <div class="tog-temp">Room temp 20–24°C</div>
          <p class="tog-desc">Best-selling weight for spring and autumn. Versatile for year-round stocking. Available in all fabric options.</p>
          <div class="tog-link">View Details →</div>
        </a>

        <a href="/products/tog-25" class="tog-card card tog-autumn">
          <div class="tog-season-icon">🍂</div>
          <div class="tog-number">2.5</div>
          <div class="tog-name">TOG Winter Bag</div>
          <div class="tog-temp">Room temp 16–20°C</div>
          <p class="tog-desc">Warm and cozy for autumn and winter nights. Popular with European and North American buyers. Premium fill options.</p>
          <div class="tog-link">View Details →</div>
        </a>

        <a href="/products/tog-35" class="tog-card card tog-winter">
          <div class="tog-season-icon">❄️</div>
          <div class="tog-number">3.5</div>
          <div class="tog-name">TOG Cold-Climate Bag</div>
          <div class="tog-temp">Room temp 12–16°C</div>
          <p class="tog-desc">Maximum warmth for cold climates and Nordic markets. Merino wool and heavyweight fill available.</p>
          <div class="tog-link">View Details →</div>
        </a>
      </div>

      <div class="size-note">
        <span>📏</span>
        <span><strong>Standard Sizes:</strong> Newborn (0–3M) · Small (3–9M) · Medium (9–18M) · Large (18–36M) — Custom fit grading available on request</span>
      </div>
    </div>
  </section>

  <!-- ═══ OEM/ODM ═══ -->
  <section class="section oem-section" id="oem">
    <div class="container">
      <div class="oem-inner">
        <div class="oem-content">
          <div class="label">OEM / ODM Services</div>
          <h2 class="section-heading">Your Brand.<br/><em>Our Factory.</em></h2>
          <p class="section-sub">From mood board to finished product — we handle every step. Bring us a tech pack, a sample, or just an idea.</p>

          <div class="oem-list">
            {[
              { icon: "🎨", title: "Fabric & Color Development", desc: "Pantone matching, exclusive dye lots, custom fabric weights and knit structures." },
              { icon: "🖨️", title: "Print & Embroidery", desc: "All-over prints, placement prints, woven labels, embroidered logos. Non-toxic inks." },
              { icon: "📐", title: "Custom Sizing & Grading", desc: "Work from your spec sheet or we develop a graded size chart from scratch." },
              { icon: "🔗", title: "Zipper & Hardware Options", desc: "Two-way zippers, safety flaps, snap closures. EN 16781 compliant throughout." },
              { icon: "🏷️", title: "Private Label & Packaging", desc: "Woven labels, hang tags, care labels, custom retail packaging ready for your market." },
            ].map(item => (
              <div class="oem-item">
                <span class="oem-icon">{item.icon}</span>
                <div>
                  <h4>{item.title}</h4>
                  <p>{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="oem-process">
          <div class="process-card card">
            <h3 style="font-size:1.5rem;color:var(--warm);margin-bottom:1.5rem;">How It Works</h3>
            {[
              { step: "01", title: "Send Inquiry", desc: "Share your requirements via form or WhatsApp" },
              { step: "02", title: "Quotation", desc: "Detailed pricing within 24–48 hours" },
              { step: "03", title: "Sample", desc: "Pre-production sample in 10–15 days" },
              { step: "04", title: "Approval", desc: "Review, approve, and confirm bulk order" },
              { step: "05", title: "Production & Ship", desc: "Bulk ready in 30–45 days · FOB Qingdao" },
            ].map(item => (
              <div class="process-step">
                <div class="process-num">{item.step}</div>
                <div>
                  <h4>{item.title}</h4>
                  <p>{item.desc}</p>
                </div>
              </div>
            ))}
            <a href="#contact" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:1.5rem;">Start My Order →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MATERIALS ═══ -->
  <section class="section" id="materials">
    <div class="container">
      <div class="section-header">
        <div class="label">Material Options</div>
        <h2 class="section-heading">Three Premium <em>Fabrics</em></h2>
        <p class="section-sub">Every material is safety-tested for infants and available in GOTS-certified organic versions.</p>
      </div>

      <div class="mat-grid">
        {[
          {
            icon: "🌿", name: "Organic Cotton",
            desc: "Our bestseller — breathable, hypoallergenic, and year-round comfortable. Available in jersey, interlock, and waffle knit.",
            tags: ["GOTS Certified", "Hypoallergenic", "Breathable", "Soft-touch finish"],
            color: "sage",
          },
          {
            icon: "🎋", name: "Bamboo Blend",
            desc: "Naturally antibacterial and moisture-wicking. Bamboo viscose blends deliver silky softness and temperature regulation.",
            tags: ["Antibacterial", "Moisture-wicking", "Ultra-soft", "Thermo-regulating"],
            color: "sky",
          },
          {
            icon: "🐑", name: "Merino Wool",
            desc: "Premium natural insulation for winter and cold-climate collections. Machine washable in fine gauges, non-itch.",
            tags: ["Natural insulation", "Temp-regulating", "Machine washable", "Non-itch fine gauge"],
            color: "peach",
          },
        ].map(mat => (
          <div class={`mat-card card mat-${mat.color}`}>
            <div class="mat-icon">{mat.icon}</div>
            <h3>{mat.name}</h3>
            <p>{mat.desc}</p>
            <div class="mat-tags">
              {mat.tags.map(tag => <span class="pill pill-cream">{tag}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CERTIFICATIONS ═══ -->
  <section class="section cert-section" id="certifications">
    <div class="container">
      <div class="cert-inner">
        <div>
          <div class="label">Certifications</div>
          <h2 class="section-heading">Built for <em>Global</em> Markets</h2>
          <p class="section-sub" style="margin-bottom:2rem;">Our certifications are your sourcing shortcut — proof of organic integrity, ethical production, and safety compliance.</p>
          <a href="#contact" class="btn btn-primary">Request Audit Reports</a>
        </div>

        <div class="cert-cards">
          {[
            {
              badge: "🌱", color: "green",
              title: "GOTS — Global Organic Textile Standard",
              desc: "Full organic supply chain certification from raw fiber to finished product. Required by most EU and North American organic baby brands.",
            },
            {
              badge: "✅", color: "blue",
              title: "BSCI — Business Social Compliance Initiative",
              desc: "Factory audited for fair labor, safe working conditions, and ethical sourcing. Audit reports available on request.",
            },
            {
              badge: "🛡️", color: "orange",
              title: "EN 16781 Safety Compliance",
              desc: "Our sleeping bags are designed and tested to meet European safety standard EN 16781 for infant sleep products.",
            },
          ].map(cert => (
            <div class={`cert-card card cert-${cert.color}`}>
              <div class={`cert-badge badge-${cert.color}`}>{cert.badge}</div>
              <div>
                <h4>{cert.title}</h4>
                <p>{cert.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-form-wrap card">
          <h3 class="form-title">Request a Quote or Sample</h3>
          <form
            action="https://formspree.io/f/xykblbyv"
            method="POST"
            class="contact-form"
          >
            <div class="form-row-2">
              <div class="form-group">
                <label>Your Name</label>
                <input type="text" name="name" placeholder="Jane Smith" required />
              </div>
              <div class="form-group">
                <label>Company</label>
                <input type="text" name="company" placeholder="Brand / Retailer" required />
              </div>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="jane@yourbrand.com" required />
            </div>
            <div class="form-row-2">
              <div class="form-group">
                <label>TOG Interest</label>
                <select name="tog">
                  <option>TOG 0.5 Summer</option>
                  <option>TOG 1.0 All-Season</option>
                  <option>TOG 2.5 Winter</option>
                  <option>TOG 3.5 Cold Climate</option>
                  <option>Multiple / Not Sure</option>
                </select>
              </div>
              <div class="form-group">
                <label>Estimated Quantity</label>
                <select name="quantity">
                  <option>100–500 pcs</option>
                  <option>500–1,000 pcs</option>
                  <option>1,000–3,000 pcs</option>
                  <option>3,000+ pcs</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label>Your Requirements</label>
              <textarea name="message" placeholder="Tell us about your product — TOG, material, sizes, certifications needed, timeline, custom requirements..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary submit-btn">Send Inquiry →</button>
          </form>
        </div>

        <div class="contact-info">
          <div class="label">Get In Touch</div>
          <h2 class="section-heading">Let's <em>Create</em> Together</h2>
          <p class="section-sub">We reply to all inquiries within 24 hours (Mon–Fri). For urgent requests, WhatsApp is fastest.</p>

          <div class="info-items">
            {[
              { icon: "🏭", label: "Company", value: "Taian Lianchuang Textile Co., Ltd." },
              { icon: "📍", label: "Address", value: "Tianzhufeng Road, Tai'an City\nShandong Province, China 271000" },
              { icon: "📱", label: "WhatsApp / WeChat / Tel", value: "+86 182 6538 1705", href: "https://wa.me/8618265381705" },
            ].map(info => (
              <div class="info-item">
                <div class="info-icon">{info.icon}</div>
                <div>
                  <div class="info-label">{info.label}</div>
                  {info.href
                    ? <a href={info.href} class="info-value info-link">{info.value}</a>
                    : <div class="info-value" style="white-space:pre-line">{info.value}</div>
                  }
                </div>
              </div>
            ))}
          </div>

          <div class="whatsapp-btn-wrap">
            <a href="https://wa.me/8618265381705" class="btn btn-primary whatsapp-btn">
              💬 Chat on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* ── HERO ── */
.hero {
  min-height: 100vh; padding: 120px 0 80px;
  position: relative; overflow: hidden;
}
.hero-bg-blob {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.blob1 {
  width: 600px; height: 600px; top: -150px; right: -100px;
  background: radial-gradient(circle, rgba(232,184,154,0.25) 0%, transparent 70%);
  animation: float 10s ease-in-out infinite;
}
.blob2 {
  width: 400px; height: 400px; bottom: -100px; left: -80px;
  background: radial-gradient(circle, rgba(122,158,126,0.2) 0%, transparent 70%);
  animation: float 13s ease-in-out infinite reverse;
}
.hero-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  align-items: center; gap: 4rem; position: relative; z-index: 1;
}
.hero-badges { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
.hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.6rem, 4.5vw, 4rem);
  color: var(--warm); line-height: 1.1; margin-bottom: 1.2rem;
}
.hero h1 em { color: var(--blush); font-style: italic; }
.hero-sub {
  font-size: 1.05rem; color: var(--text-light);
  line-height: 1.8; font-weight: 300; margin-bottom: 2rem; max-width: 480px;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.hero-stats {
  display: flex; align-items: center; gap: 1.5rem;
  padding: 1.2rem 1.5rem;
  background: white; border-radius: 20px; border: 1px solid var(--border);
  width: fit-content;
}
.stat { text-align: center; }
.stat-num {
  display: block;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem; font-weight: 600; color: var(--warm);
}
.stat-label { font-size: 0.72rem; color: var(--text-light); }
.stat-divider { width: 1px; height: 36px; background: var(--border); }

/* Hero visual */
.hero-visual { position: relative; }
.hero-card-main {
  position: relative; z-index: 2;
  margin-bottom: 160px;
}
.product-visual {
  height: 200px; border-radius: 16px; margin-bottom: 1.2rem;
  background: linear-gradient(135deg, rgba(196,218,189,0.3), rgba(232,184,154,0.3));
  display: flex; align-items: center; justify-content: center;
  font-size: 6rem; position: relative; overflow: hidden;
}
.product-glow {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.6), transparent 60%);
}
.product-info { margin-bottom: 1rem; }
.product-info h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem; color: var(--warm); margin-bottom: 0.3rem;
}
.product-info p { font-size: 0.82rem; color: var(--text-light); }
.cert-pills { display: flex; gap: 0.4rem; flex-wrap: wrap; }

.hero-float-card {
  position: absolute; padding: 1.2rem 1.4rem; z-index: 3;
}
.hero-float-card strong { display: block; font-size: 0.9rem; color: var(--warm); margin-bottom: 0.2rem; }
.hero-float-card p { font-size: 0.78rem; color: var(--text-light); }
.float-card-1 { bottom: 10px; left: -30px; width: 200px; animation: float 7s ease-in-out infinite; }
.float-card-2 { top: 30px; right: -20px; width: 180px; animation: float 9s ease-in-out infinite reverse; }

/* Trust bar */
.trust-bar { background: var(--warm); padding: 1rem 0; }
.trust-inner {
  display: flex; align-items: center; justify-content: center;
  flex-wrap: wrap; gap: 0.6rem;
}
.trust-item { font-size: 0.8rem; color: rgba(255,255,255,0.8); white-space: nowrap; }
.trust-sep { color: rgba(255,255,255,0.3); }

/* TOG products */
.section-header { text-align: center; margin-bottom: 3rem; }
.section-header .section-sub { margin: 0 auto; }
.tog-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.2rem; margin-bottom: 1.5rem; }
.tog-grid-5 { grid-template-columns: repeat(5,1fr); }
.tog-muted { border-top-color: #87a878; }
.tog-card-featured { position: relative; }
.tog-featured-badge {
  display: inline-block; background: #87a878; color: white;
  font-size: 0.68rem; font-weight: 600; letter-spacing: 0.06em;
  padding: 0.2rem 0.6rem; border-radius: 50px;
  text-transform: uppercase; margin-bottom: 0.5rem;
}
.tog-card {
  display: block; text-decoration: none; color: inherit;
  border-top: 4px solid transparent; position: relative;
}
.tog-summer { border-top-color: #5A9BBF; }
.tog-spring { border-top-color: var(--sage); }
.tog-autumn { border-top-color: var(--blush); }
.tog-winter { border-top-color: #7B68EE; }
.tog-season-icon { font-size: 2rem; margin-bottom: 0.6rem; }
.tog-number {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.8rem; font-weight: 600; color: var(--warm); line-height: 1;
}
.tog-name { font-weight: 600; font-size: 0.92rem; color: var(--warm); margin: 0.3rem 0; }
.tog-temp { font-size: 0.75rem; color: var(--text-light); margin-bottom: 0.8rem; }
.tog-desc { font-size: 0.82rem; color: var(--text-light); line-height: 1.6; margin-bottom: 1rem; }
.tog-link { font-size: 0.8rem; color: var(--blush); font-weight: 500; }
.size-note {
  display: flex; align-items: center; gap: 0.8rem;
  padding: 1.2rem 1.8rem; border-radius: 16px;
  background: white; border: 1px solid var(--border);
  font-size: 0.85rem; color: var(--text-light);
}

/* OEM section */
.oem-section { background: white; }
.oem-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.oem-list { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 2rem; }
.oem-item { display: flex; gap: 1rem; align-items: flex-start; }
.oem-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
.oem-item h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem; color: var(--warm); margin-bottom: 0.25rem;
}
.oem-item p { font-size: 0.83rem; color: var(--text-light); line-height: 1.6; }
.process-card { padding: 2rem; }
.process-step { display: flex; gap: 1rem; margin-bottom: 1.2rem; align-items: flex-start; }
.process-num {
  width: 32px; height: 32px; border-radius: 10px;
  background: var(--blush); color: white;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; font-weight: 600; flex-shrink: 0;
}
.process-step h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem; color: var(--warm); margin-bottom: 0.2rem;
}
