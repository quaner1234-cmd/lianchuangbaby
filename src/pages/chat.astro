---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Online Support">
  <div style="max-width: 900px; margin: 0 auto; padding: 2rem;">
    <h1 style="text-align: center; margin-bottom: 1.5rem;">Online Support</h1>
    <iframe
      src="https://udify.app/chatbot/Co519WlZODEpVpyv"
      style="width: 100%; height: 700px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);"
      frameborder="0"
      allow="microphone">
    </iframe>
  </div>
</Layout>