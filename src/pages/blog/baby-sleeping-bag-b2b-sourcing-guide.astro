            <a href="/blog/organic-cotton-vs-bamboo-vs-merino">Cotton vs Bamboo vs Merino</a>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <Footer />
</Base>

<style>
.article-hero {
  padding: 130px 0 60px;
  background: linear-gradient(135deg, var(--cream), var(--cream-dark));
  border-bottom: 1px solid var(--border);
}
.article-hero h1 {
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  color: var(--warm); margin-bottom: 1rem; max-width: 700px;
}
.article-meta {
  display: flex; gap: 0.6rem;
  font-size: 0.8rem; color: var(--text-light);
}
.article-body {
  display: grid; grid-template-columns: 1fr 320px;
  gap: 4rem; padding: 4rem 5%; align-items: start;
}
.article-content { max-width: 720px; }
.lead {
  font-size: 1.1rem; color: var(--text-light);
  line-height: 1.85; font-weight: 300; margin-bottom: 2rem;
  border-left: 3px solid var(--blush); padding-left: 1.2rem;
}
.article-content h2 {
  font-size: 1.5rem; color: var(--warm);
  margin: 2.5rem 0 0.8rem;
}
.article-content h3 {
  font-size: 1.1rem; color: var(--warm);
  margin: 1.5rem 0 0.6rem;
}
.article-content p {
  font-size: 0.95rem; color: var(--text-light);
  line-height: 1.85; margin-bottom: 1rem; font-weight: 300;
}
.article-content ul {
  padding-left: 1.4rem; margin-bottom: 1rem;
}
.article-content ul li {
  font-size: 0.95rem; color: var(--text-light);
  line-height: 1.85; font-weight: 300; margin-bottom: 0.4rem;
}
.article-img {
  width: 100%; border-radius: 16px;
  margin: 2rem 0; object-fit: cover; max-height: 420px;
  border: 1px solid var(--border);
}
blockquote {
  background: var(--cream); border-left: 3px solid var(--blush);
  padding: 1rem 1.4rem; border-radius: 0 12px 12px 0;
  margin: 1.5rem 0; font-size: 0.92rem; color: var(--text-light);
  line-height: 1.75; font-style: italic; font-weight: 300;
}

/* Data tables */
