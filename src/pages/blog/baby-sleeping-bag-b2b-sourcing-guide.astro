  border: 1px solid var(--border); border-radius: 16px;
  overflow: hidden; margin: 1.5rem 0;
}
.table-row {
  display: grid; grid-template-columns: 1fr 1fr 1.5fr;
  padding: 0.9rem 1.2rem; gap: 1rem;
  border-bottom: 1px solid var(--border);
  font-size: 0.85rem; align-items: center; color: var(--text-light);
}
.table-row.table-header {
  background: var(--warm); color: white;
  font-size: 0.75rem; font-weight: 600; letter-spacing: 0.06em;
}
.table-row:last-child { border-bottom: none; }
.table-row:nth-child(even):not(.table-header) { background: var(--cream); }
.data-table:has(.table-row:nth-child(2):last-child) .table-row,
.data-table .table-row:only-of-type { grid-template-columns: 1fr 2fr; }
.tog-val { font-weight: 700; font-size: 1rem; color: var(--blush); }

/* Two-column tables */
.data-table.two-col .table-row { grid-template-columns: 1fr 2fr; }

/* About box */
.about-box {
  background: var(--cream); border-radius: 20px;
  padding: 2rem; margin-top: 2.5rem; border: 1px solid var(--border);
}
.about-box h3 {
  font-size: 1.1rem; color: var(--warm); margin-bottom: 0.8rem;
