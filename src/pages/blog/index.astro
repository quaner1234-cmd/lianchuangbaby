---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    slug: "merino-wool-baby-sleepwear-guide",
    title: "From Pasture to Pajamas: The Complete Manufacturer's Guide to Merino Wool for Baby Sleeping Bags",
    date: "2026-05-17",
    excerpt: "Where merino wool comes from, why it performs the way it does, how it became the fabric of choice for premium baby sleepwear, and what brands need to know when sourcing it responsibly.",
    category: "Materials",
  },
  {
    slug: "lullaby-trust-safer-sleep-guide",
    title: "What the Lullaby Trust Actually Says About Baby Sleeping Bags — A Factory's Reading Notes",
    date: "2026-04-21",
    excerpt: "A manufacturer's close reading of Lullaby Trust safer sleep guidance — with the production context that usually gets left out. TOG accuracy, fit, fabric choice, and what safety standards actually cover.",
    category: "Safety & Standards",
  },
  {
    slug: "2026-global-baby-sleeping-bag-trends",
    title: "2026 Global Baby Sleeping Bag Trends: Beyond Muted Tones and Minimalist Design",
    date: "2026-04-20",
    excerpt: "Deep & moody tones, PCM thermal regulation, silent hardware, and post-weighted safety innovations — a comprehensive B2B analysis of where the baby sleeping bag market is heading.",
    category: "Trend Report",
  },
  {
    slug: "baby-sleeping-bag-b2b-sourcing-guide",
    title: "Baby Sleeping Bag B2B Buyer Guide: Top 5 Questions Every Wholesale Buyer Asks Before Placing an Order",
    date: "2026-04-19",
    excerpt: "A practical sourcing guide covering TOG ratings, safety certifications (GOTS, EN 16781), MOQ benchmarks, natural fiber options, and private label support for wholesale buyers.",
    category: "Sourcing Guide",
  },
  {
    slug: "the-rise-of-muted-tones",
    title: "The Rise of Muted Tones: How \"Emotional Parenting\" is Shaping the 2026 Baby Sleep Market",
    date: "2026-04-18",
    excerpt: "Leading global brands are pivoting toward Sage Green, Terracotta, and Sand. Discover the science and strategy behind the Muted Tones movement in baby sleeping bags.",
    category: "Trend Report",
  },
  {
    slug: "understanding-baby-sleeping-bags-first-principles-guide",
    title: "Understanding the Baby Sleeping Bag Industry: A First-Principles Guide for Buyers and Brands",
    date: "2026-04-17",
    excerpt: "From the 1994 Back to Sleep campaign to today's GOTS requirements — a seven-step framework covering the science, standards, materials, and future of the infant sleep bag category.",
    category: "Industry Guide",
  },
  {
    slug: "what-is-tog-rating",
    title: "What Is TOG Rating? A Complete Guide for Baby Sleeping Bags",
    date: "2025-03-01",
    excerpt: "TOG stands for Thermal Overall Grade — the standard measure of warmth in baby sleeping bags. Here's everything buyers need to know.",
    category: "Buyer's Guide",
  },
  {
    slug: "gots-certified-baby-products",
    title: "Why GOTS Certification Matters for Baby Sleeping Bags",
    date: "2025-03-15",
    excerpt: "GOTS is the gold standard for organic textiles. We explain what it means, what it covers, and why your brand should demand it from suppliers.",
    category: "Certifications",
  },
  {
    slug: "organic-cotton-vs-bamboo-vs-merino",
    title: "Organic Cotton vs Bamboo vs Merino: Which Fabric for Baby Sleeping Bags?",
    date: "2025-04-01",
    excerpt: "A practical comparison of the three most popular fabrics for infant sleep products — softness, breathability, sustainability, and cost.",
    category: "Materials",
  },
  {
    slug: "en-16781-safety-standard",
    title: "EN 16781 Explained: European Safety Standard for Baby Sleeping Bags",
    date: "2025-04-15",
    excerpt: "Selling in Europe? EN 16781 is mandatory. Here's what the standard requires and how our factory ensures full compliance.",
    category: "Safety & Standards",
  },
];
---

<Base
  title="Baby Sleeping Bag Industry Blog | Lianchuang Textile"
  description="Expert articles on TOG ratings, organic certifications, fabric choices, and safety standards for baby sleeping bag buyers and brands."
>
  <Nav />

  <section class="blog-hero">
    <div class="container">
      <div class="label">Industry Knowledge</div>
      <h1>Baby Sleeping Bag <em>Blog</em></h1>
      <p>Expert guides on TOG ratings, certifications, fabric options, and safety standards — for brands and buyers sourcing infant sleep products.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="posts-grid">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card card">
            <div class="post-cat">{post.category}</div>
            <h2>{post.title}</h2>
            <p>{post.excerpt}</p>
            <div class="post-footer">
              <span class="post-date">{post.date}</span>
              <span class="post-read">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
.blog-hero {
  padding: 140px 0 80px;
  text-align: center;
  background: linear-gradient(135deg, var(--cream), var(--cream-dark));
  border-bottom: 1px solid var(--border);
}
.blog-hero h1 {
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  color: var(--warm); margin-bottom: 1rem;
}
.blog-hero h1 em { color: var(--blush); font-style: italic; }
.blog-hero p {
  font-size: 1rem; color: var(--text-light);
  max-width: 560px; margin: 0 auto; line-height: 1.8; font-weight: 300;
}
.posts-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.post-card { display: block; color: inherit; }
.post-cat {
  font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--blush); font-weight: 600; margin-bottom: 0.6rem;
}
.post-card h2 {
  font-size: 1.2rem; color: var(--warm); margin-bottom: 0.6rem; line-height: 1.3;
}
.post-card p { font-size: 0.85rem; color: var(--text-light); line-height: 1.7; margin-bottom: 1rem; }
.post-footer { display: flex; justify-content: space-between; align-items: center; }
.post-date { font-size: 0.75rem; color: var(--text-light); }
.post-read { font-size: 0.82rem; color: var(--blush); font-weight: 500; }

@media (max-width: 640px) {
  .posts-grid { grid-template-columns: 1fr; }
}
</style>
