---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Premium Muslin Baby Sleeping Bag – Summer Muted Tones Series | OEM/ODM Manufacturer"
  description="Factory-direct Premium Muslin Baby Sleeping Bag in Sage Green, Terracotta & Sand. 0.5 TOG, OEKO-TEX certified, OEM/ODM. Designed for the 2026 'Emotional Parenting' aesthetic trend."
>
  <Nav />

  <section class="product-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> <span>›</span>
        <a href="/#products">Products</a> <span>›</span>
        <span>Premium Muslin – Muted Tones</span>
      </div>

      <div class="product-hero-inner">
        <div class="product-hero-content">
          <div class="series-badge">
            <span class="badge-dot"></span>
            <span>2026 Summer Collection · Trending Now</span>
          </div>

          <h1>Premium Muslin Baby Sleeping Bag</h1>
          <p class="product-subtitle">Summer "Muted Tones" Series (OEM/ODM)</p>
          <p class="product-intro">
            Elevate your nursery collection with sustainable aesthetics and scientifically‑backed color palettes designed for better infant sleep.
          </p>

          <div class="palette-chips">
            <div class="chip chip-sage">
              <span class="chip-swatch"></span>
              Sage Green
            </div>
            <div class="chip chip-terra">
              <span class="chip-swatch"></span>
              Terracotta
            </div>
            <div class="chip chip-sand">
              <span class="chip-swatch"></span>
              Sand
            </div>
          </div>

          <div class="product-meta">
            <div class="meta-item">
              <span class="meta-label">TOG Rating</span>
              <span class="meta-value">0.5 TOG</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Room Temperature</span>
              <span class="meta-value">24–27°C / 75–81°F</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">MOQ</span>
              <span class="meta-value">500 units / style</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Sample Lead Time</span>
              <span class="meta-value">7–10 days</span>
            </div>
          </div>

          <div class="product-actions">
            <a href="/#contact" class="btn btn-primary">Request Sample →</a>
            <a href="/#contact" class="btn btn-outline">Get Wholesale Pricing</a>
          </div>
        </div>

        <div class="product-visual-wrap">
          <div class="product-visual-card card">
            <img
              src="/muted-tones-1.jpg"
              alt="Premium Muslin Baby Sleeping Bag – Muted Tones Series hero shot"
              class="hero-product-img"
            />
            <div class="product-cert-pills">
              <span class="pill pill-green">🌱 OEKO-TEX® Std 100</span>
              <span class="pill pill-peach">✅ CPC Certified</span>
              <span class="pill pill-cream">🛡️ EN 16781</span>
              <span class="pill pill-cream">Hip Healthy</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OVERVIEW ═══ -->
  <section class="section overview-section">
    <div class="container">
      <div class="overview-inner">
        <div class="overview-text">
          <div class="label">Product Overview</div>
          <h2 class="section-heading">The New Era of <em>"Emotional Parenting"</em> Aesthetics</h2>
          <p>
            In a market shifting away from loud, neon patterns, our Muted Tones Series leads the trend in "Emotional Parenting." Featuring a palette of Sage Green, Terracotta, and Neutral Earth Tones, these colors are selected not just for their beauty, but for their ability to create a calming sleep environment.
          </p>
          <p>
            This collection aligns perfectly with the "Sustainable Fashion" visual identity that modern parents demand — and that today's most influential baby brands are built around.
          </p>
          <p>
            Designed specifically for high-temperature climates, our summer sleep sacks utilize high-performance muslin blends that prioritize airflow and thermal regulation. We combine the softness of organic fibers with professional-grade construction to ensure durability through repeated industrial laundering.
          </p>
        </div>

        <div class="overview-image">
          <img
            src="/muted-tones-2.jpg"
            alt="Premium Muslin Baby Sleeping Bag – Muted Tones color palette lifestyle"
            class="overview-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KEY FEATURES ═══ -->
  <section class="section features-section">
    <div class="container">
      <div class="section-header">
        <div class="label">Key Features</div>
        <h2 class="section-heading">Designed to <em>Sell & Perform</em></h2>
        <p class="section-sub">Every detail is crafted to satisfy the modern parent and meet the demands of global retail buyers.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card card">
          <div class="feature-icon">🎨</div>
          <h3>The Muted Palette</h3>
          <p>Sage Green, Terracotta, and Sand — the definitive trending colors for the 2026 nursery market. Exclusive to our Muted Tones Series.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon">🌬️</div>
          <h3>Optimal Breathability</h3>
          <p>Ultra-lightweight muslin construction (RET optimized) ensures maximum ventilation to prevent overheating during summer nights.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon">🌿</div>
          <h3>Eco-Conscious & Sustainable</h3>
          <p>Made with eco-friendly dyes, compliant with OEKO-TEX® Standard 100. Appeals to environmentally conscious consumers and ESG-focused buyers.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon">🔒</div>
          <h3>Ergonomic Safety Design</h3>
          <p>Two-way safety zipper with integrated chin guard. Bell-shaped bottom supports healthy hip development — Hip Healthy certified.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon">✨</div>
          <h3>Premium Softness</h3>
          <p>Pre-washed fabric that maintains structural integrity while becoming softer with every wash. Parents notice the quality difference immediately.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon">🏭</div>
          <h3>19 Years of Manufacturing</h3>
          <p>Leverage our deep manufacturing expertise and multi-factory infrastructure — including SE Asia facilities for tariff optimization.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TECH SPECS ═══ -->
  <section class="section specs-section">
    <div class="container">
      <div class="section-header">
        <div class="label">Technical Specifications</div>
        <h2 class="section-heading">Built to <em>Spec</em></h2>
      </div>

      <div class="specs-table-wrap card">
        <table class="specs-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Material</td>
              <td>100% Organic Cotton Muslin / Bamboo-Cotton Blend <em>(Customizable)</em></td>
            </tr>
            <tr>
              <td>TOG Rating</td>
              <td>0.5 TOG — ideal for room temperatures 24°C–27°C / 75°F–81°F</td>
            </tr>
            <tr>
              <td>Sizes</td>
              <td>S (0–6M) · M (6–18M) · L (18–36M) · XL (3–5Y)</td>
            </tr>
            <tr>
              <td>Certifications</td>
              <td>CPC · EN 16781 · REACH · OEKO-TEX® Standard 100</td>
            </tr>
            <tr>
              <td>Care</td>
              <td>Machine wash cold · Tumble dry low</td>
            </tr>
            <tr>
              <td>MOQ</td>
              <td>500 units per style (flexible color-way distribution available)</td>
            </tr>
            <tr>
              <td>Sample Lead Time</td>
              <td>7–10 business days</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ B2B INFO ═══ -->
  <section class="section b2b-section">
    <div class="container">
      <div class="b2b-inner">
        <div class="b2b-content">
          <div class="label">B2B &amp; Supply Chain</div>
          <h2 class="section-heading">Scale Your Collection with <em>Confidence</em></h2>
          <p class="section-sub">
            Leverage our 19 years of manufacturing expertise and multi-factory infrastructure for your private label needs.
          </p>

          <div class="b2b-list">
            <div class="b2b-item">
              <span class="b2b-icon">📦</span>
              <div>
                <h4>Flexible MOQ</h4>
                <p>500 units per style with flexible color-way distribution — mix Sage Green, Terracotta, and Sand across your order.</p>
              </div>
            </div>
            <div class="b2b-item">
              <span class="b2b-icon">🏷️</span>
              <div>
                <h4>Full OEM/ODM Services</h4>
                <p>Private labeling, custom embroidery, proprietary pattern development. Your brand, our expertise.</p>
              </div>
            </div>
            <div class="b2b-item">
              <span class="b2b-icon">🌏</span>
              <div>
                <h4>Tariff-Optimized Production</h4>
                <p>Strategic production capabilities including SE Asia facilities to ensure stable lead times and tariff optimization for your target markets.</p>
              </div>
            </div>
            <div class="b2b-item">
              <span class="b2b-icon">🧪</span>
              <div>
                <h4>Professional Sampling</h4>
                <p>Pre-production prototypes delivered within 7–10 business days. Review, refine, and approve before bulk commitment.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="b2b-cta-card card">
          <h3>Scale Your Collection with the 2026 Summer Series</h3>
          <p>
            Looking for a reliable manufacturing partner to bring your "Muted Tones" vision to life? Contact our export specialists today for a digital catalog and wholesale pricing.
          </p>
          <ul class="cta-checklist">
            <li>✓ Digital catalog sent within 24 hours</li>
            <li>✓ Wholesale pricing &amp; FOB quote</li>
            <li>✓ Pantone-matched sample available</li>
            <li>✓ NDA available on request</li>
          </ul>
          <a href="/#contact" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:1.5rem;">
            Contact Export Specialists →
          </a>
          <a href="https://wa.me/8618265381705" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:0.8rem;">
            💬 WhatsApp Us Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* Hero */
.product-hero {
  padding: 120px 0 80px;
  background: linear-gradient(135deg, #f9f5f0, #f2ede6);
  border-bottom: 1px solid var(--border);
}
.breadcrumb {
  font-size: 0.78rem; color: var(--text-light);
  display: flex; gap: 0.5rem; align-items: center;
  margin-bottom: 2.5rem;
}
.breadcrumb a { color: var(--text-light); }
.breadcrumb a:hover { color: var(--blush); }
.product-hero-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: center;
}
.series-badge {
  display: inline-flex; align-items: center; gap: 0.6rem;
  background: rgba(255,255,255,0.7); border: 1px solid var(--border);
  border-radius: 50px; padding: 0.35rem 1rem;
  font-size: 0.82rem; font-weight: 500; color: var(--warm);
  margin-bottom: 1rem; border-left: 3px solid #8fad7c;
}
.badge-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #8fad7c; display: inline-block;
  animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.product-hero h1 {
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  color: var(--warm); margin-bottom: 0.4rem;
}
.product-subtitle {
  font-size: 1rem; color: var(--blush); font-weight: 500;
  margin-bottom: 1rem;
}
.product-intro {
  font-size: 0.97rem; color: var(--text-light);
  line-height: 1.8; margin-bottom: 1.5rem; font-weight: 300;
}
.palette-chips {
  display: flex; gap: 0.6rem; margin-bottom: 1.8rem; flex-wrap: wrap;
}
.chip {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.3rem 0.9rem; border-radius: 50px;
  font-size: 0.8rem; font-weight: 500; border: 1px solid rgba(0,0,0,0.08);
  background: white;
}
.chip-swatch {
  width: 12px; height: 12px; border-radius: 50%; display: inline-block;
}
.chip-sage .chip-swatch { background: #87a878; }
.chip-terra .chip-swatch { background: #c4754a; }
.chip-sand .chip-swatch { background: #c9b89a; }
.product-meta {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 0.8rem; margin-bottom: 2rem;
}
.meta-item {
  background: white; border-radius: 14px; padding: 0.8rem 1rem;
  border: 1px solid var(--border);
}
.meta-label { display: block; font-size: 0.7rem; color: var(--text-light); letter-spacing: 0.06em; margin-bottom: 0.2rem; }
.meta-value { font-size: 0.92rem; font-weight: 600; color: var(--warm); }
.product-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

/* Hero image */
.product-visual-card {
  overflow: hidden; padding: 0;
}
.hero-product-img {
  width: 100%; display: block;
  border-radius: 20px 20px 0 0;
  object-fit: cover; aspect-ratio: 4/3;
}
.product-cert-pills {
  display: flex; flex-wrap: wrap; gap: 0.4rem; padding: 1rem 1.2rem;
}

/* Overview */
.overview-section { background: white; }
.overview-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: center;
}
.overview-text p {
  font-size: 0.92rem; color: var(--text-light);
  line-height: 1.85; margin-bottom: 1rem;
}
.overview-img {
  width: 100%; border-radius: 20px;
  object-fit: cover; aspect-ratio: 3/4;
  box-shadow: 0 12px 40px rgba(0,0,0,0.08);
}

/* Features */
.features-section { background: var(--cream); }
.features-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem; margin-top: 3rem;
}
.feature-card { text-align: left; }
.feature-icon { font-size: 2rem; margin-bottom: 0.8rem; }
.feature-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem; color: var(--warm); margin-bottom: 0.5rem;
}
.feature-card p { font-size: 0.85rem; color: var(--text-light); line-height: 1.7; }

/* Specs */
.specs-section { background: white; }
.specs-table-wrap { padding: 0; overflow: hidden; }
.specs-table { width: 100%; border-collapse: collapse; }
.specs-table th, .specs-table td {
  padding: 1rem 1.5rem; text-align: left;
  border-bottom: 1px solid var(--border);
  font-size: 0.88rem;
}
.specs-table th {
  background: var(--cream); font-weight: 600;
  color: var(--warm); font-size: 0.78rem;
  letter-spacing: 0.06em; text-transform: uppercase;
}
.specs-table td:first-child { color: var(--warm); font-weight: 600; white-space: nowrap; }
.specs-table td:last-child { color: var(--text-light); }
.specs-table td em { color: var(--blush); font-style: normal; font-size: 0.82rem; }
.specs-table tr:last-child td { border-bottom: none; }

/* B2B */
.b2b-section { background: linear-gradient(135deg, rgba(196,218,189,0.12), rgba(184,216,232,0.08)); }
.b2b-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: start;
}
.b2b-list { display: flex; flex-direction: column; gap: 1.4rem; margin-top: 2rem; }
.b2b-item { display: flex; gap: 1rem; align-items: flex-start; }
.b2b-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
.b2b-item h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem; color: var(--warm); margin-bottom: 0.25rem;
}
.b2b-item p { font-size: 0.83rem; color: var(--text-light); line-height: 1.65; }
.b2b-cta-card { padding: 2rem; }
.b2b-cta-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem; color: var(--warm); margin-bottom: 0.8rem;
}
.b2b-cta-card > p { font-size: 0.87rem; color: var(--text-light); line-height: 1.7; margin-bottom: 1.2rem; }
.cta-checklist {
  list-style: none; display: flex; flex-direction: column; gap: 0.5rem;
}
.cta-checklist li {
  font-size: 0.85rem; color: var(--warm); font-weight: 500;
}

/* Section header */
.section-header { text-align: center; margin-bottom: 3rem; }
.section-header .section-sub { margin: 0 auto; }

/* Responsive */
@media (max-width: 900px) {
  .product-hero-inner,
  .overview-inner,
  .b2b-inner { grid-template-columns: 1fr; gap: 2rem; }
  .product-hero { padding: 100px 0 60px; }
  .overview-img { aspect-ratio: 16/9; }
}
@media (max-width: 700px) {
  .features-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 500px) {
  .features-grid { grid-template-columns: 1fr; }
  .product-meta { grid-template-columns: 1fr 1fr; }
  .specs-table th, .specs-table td { padding: 0.75rem 1rem; }
}
</style>
