---
const title = "OEM Baby Sleeping Bag Service | Custom Manufacturing China";
const description = "Custom OEM baby sleeping bag manufacturing from China. GOTS & BSCI certified factory. Your label, your design, factory-direct pricing. Request a sample today.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #1a1a1a;
      --muted: #6b6b6b;
      --line: #e0dbd4;
      --bg: #faf9f7;
      --warm: #f4f1ec;
      --accent: #2d5a3d;
      --accent-light: #e8f0eb;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.6;
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 5vw;
      border-bottom: 1px solid var(--line);
      background: var(--bg);
    }
    .logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.15rem;
      color: var(--ink);
      text-decoration: none;
    }
    .nav-cta {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--accent);
      text-decoration: none;
      border: 1px solid var(--accent);
      padding: 0.5rem 1.1rem;
      border-radius: 2px;
      transition: background 0.2s, color 0.2s;
    }
    .nav-cta:hover { background: var(--accent); color: #fff; }

    /* HERO — darker stripe */
    .hero-wrap {
      background: #1e3a2a;
      color: #fff;
    }
    .hero {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 5vw 4rem;
    }
    .breadcrumb {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .breadcrumb a { color: rgba(255,255,255,0.45); text-decoration: none; }
    .breadcrumb a:hover { color: rgba(255,255,255,0.8); }
    h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 1.15;
      color: #fff;
      margin-bottom: 1.25rem;
      max-width: 700px;
    }
    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.65);
      max-width: 580px;
      margin-bottom: 2.5rem;
    }
    .hero-cta {
      display: inline-block;
      background: #fff;
      color: #1e3a2a;
      padding: 0.9rem 2rem;
      font-size: 0.95rem;
      font-weight: 500;
      text-decoration: none;
      border-radius: 2px;
      transition: opacity 0.2s;
    }
    .hero-cta:hover { opacity: 0.9; }

    .certs {
      background: var(--warm);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 1.25rem 5vw;
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
    }
    .cert-tag {
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--accent-light);
      padding: 0.35rem 0.9rem;
      border-radius: 2px;
    }

    section { max-width: 900px; margin: 0 auto; padding: 4rem 5vw; }
    section + section { border-top: 1px solid var(--line); }

    h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.5rem, 3vw, 2rem);
      margin-bottom: 1.75rem;
      color: var(--ink);
    }
    p { color: var(--muted); margin-bottom: 1rem; }
    p:last-child { margin-bottom: 0; }

    /* OEM FEATURES — 2 col list */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 0;
    }
    .feature {
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--line);
      display: grid;
      grid-template-columns: 2rem 1fr;
      gap: 1rem;
      align-items: start;
    }
    .feature:nth-child(odd) { padding-right: 2rem; }
    .check {
      width: 1.5rem;
      height: 1.5rem;
      background: var(--accent-light);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }
    .feature-title { font-weight: 500; color: var(--ink); font-size: 0.95rem; margin-bottom: 0.2rem; }
    .feature-desc { font-size: 0.86rem; color: var(--muted); }

    /* COMPARISON TABLE */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .compare-table th {
      text-align: left;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0.75rem 1rem;
      border-bottom: 2px solid var(--line);
    }
    .compare-table th.hl { color: var(--accent); }
    .compare-table td {
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--line);
      color: var(--ink);
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table td.hl {
      background: var(--accent-light);
      font-weight: 500;
      color: var(--accent);
    }
    .tag-yes { color: var(--accent); font-weight: 600; }
    .tag-no { color: #aaa; }

    /* PROCESS TIMELINE */
    .timeline { list-style: none; position: relative; padding-left: 2.5rem; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 0.65rem;
      top: 0.5rem;
      bottom: 0.5rem;
      width: 1px;
      background: var(--line);
    }
    .timeline li {
      position: relative;
      padding: 0 0 2rem 1.5rem;
    }
    .timeline li:last-child { padding-bottom: 0; }
    .tl-dot {
      position: absolute;
      left: -1.9rem;
      top: 0.25rem;
      width: 0.75rem;
      height: 0.75rem;
      border-radius: 50%;
      background: var(--accent);
      border: 2px solid var(--bg);
      box-shadow: 0 0 0 1px var(--accent);
    }
    .tl-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.3rem;
    }
    .tl-title { font-weight: 500; color: var(--ink); margin-bottom: 0.25rem; }
    .tl-desc { font-size: 0.88rem; color: var(--muted); }

    .cta-block {
      background: var(--accent);
      color: #fff;
      padding: 3.5rem 5vw;
      text-align: center;
    }
    .cta-block h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.5rem, 3vw, 2rem);
      color: #fff;
      margin-bottom: 0.75rem;
    }
    .cta-block p { color: rgba(255,255,255,0.75); margin-bottom: 1.75rem; }
    .cta-email {
      display: inline-block;
      background: #fff;
      color: var(--accent);
      padding: 0.9rem 2rem;
      font-size: 0.95rem;
      font-weight: 500;
      text-decoration: none;
      border-radius: 2px;
      transition: opacity 0.2s;
    }
    .cta-email:hover { opacity: 0.9; }

    footer {
      text-align: center;
      padding: 2rem 5vw;
      border-top: 1px solid var(--line);
      font-size: 0.82rem;
      color: var(--muted);
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--accent); }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="logo">Lianchuang Baby</a>
    <a href="mailto:quaner1234@gmail.com?subject=OEM Baby Sleeping Bag Inquiry" class="nav-cta">Get a Quote</a>
  </nav>

  <div class="hero-wrap">
    <div class="hero">
      <div class="breadcrumb">
        <a href="/">Home</a> &nbsp;/&nbsp; OEM Baby Sleeping Bag Service
      </div>
      <h1>OEM Baby Sleeping Bag Manufacturing — Your Brand, Our Factory</h1>
      <p class="hero-sub">Full OEM service: your labels, your packaging, your design. GOTS & BSCI certified factory in China. Low MOQ, fast samples, transparent pricing.</p>
      <a href="mailto:quaner1234@gmail.com?subject=OEM Baby Sleeping Bag Inquiry" class="hero-cta">Start Your OEM Project →</a>
    </div>
  </div>

  <div class="certs">
    <span class="cert-tag">GOTS Certified</span>
    <span class="cert-tag">BSCI Audited</span>
    <span class="cert-tag">Private Label</span>
    <span class="cert-tag">Custom Packaging</span>
    <span class="cert-tag">MOQ from 300 pcs</span>
  </div>

  <section>
    <h2>What Our OEM Service Covers</h2>
    <div class="features">
      <div class="feature">
        <div class="check">✓</div>
        <div>
          <div class="feature-title">Custom Design & Pattern</div>
          <div class="feature-desc">Send a reference or sketch — our team develops patterns, grading, and tech packs.</div>
        </div>
      </div>
      <div class="feature">
        <div class="check">✓</div>
        <div>
          <div class="feature-title">Fabric & TOG Selection</div>
          <div class="feature-desc">Organic cotton, bamboo, fleece in 0.5–3.5 TOG. Fabric swatch samples available.</div>
        </div>
      </div>
      <div class="feature">
        <div class="check">✓</div>
        <div>
          <div class="feature-title">Private Label & Branding</div>
          <div class="feature-desc">Woven labels, hang tags, care labels, barcode stickers — all to your specs.</div>
        </div>
      </div>
      <div class="feature">
        <div class="check">✓</div>
        <div>
          <div class="feature-title">Custom Packaging</div>
          <div class="feature-desc">Polybag, box, or gift bag. Retail-ready packaging available.</div>
        </div>
      </div>
      <div class="feature">
        <div class="check">✓</div>
        <div>
          <div class="feature-title">Pre-Production Samples</div>
          <div class="feature-desc">Physical samples shipped to you before bulk production begins.</div>
        </div>
      </div>
      <div class="feature">
        <div class="check">✓</div>
        <div>
          <div class="feature-title">AQL Inspection</div>
          <div class="feature-desc">Final quality inspection before shipment. Third-party inspection available.</div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <h2>OEM vs. Ready-Made — What's the Difference?</h2>
    <table class="compare-table">
      <thead>
        <tr>
          <th></th>
          <th class="hl">Our OEM Service</th>
          <th>Ready-Made / Wholesale</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Your own brand labels</td>
          <td class="hl tag-yes">✓ Included</td>
          <td class="tag-no">✗ Generic</td>
        </tr>
        <tr>
          <td>Custom design / color</td>
          <td class="hl tag-yes">✓ Full control</td>
          <td class="tag-no">✗ Fixed catalog</td>
        </tr>
        <tr>
          <td>Fabric choice</td>
          <td class="hl tag-yes">✓ Select from range</td>
          <td class="tag-no">✗ Set fabric</td>
        </tr>
        <tr>
          <td>GOTS / organic certified</td>
          <td class="hl tag-yes">✓ Available</td>
          <td class="tag-no">✗ Not guaranteed</td>
        </tr>
        <tr>
          <td>MOQ</td>
          <td class="hl">From 300 pcs/style</td>
          <td>Often 1,000+ pcs</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>OEM Timeline</h2>
    <ul class="timeline">
      <li>
        <div class="tl-dot"></div>
        <div class="tl-label">Day 1</div>
        <div class="tl-title">Send Inquiry</div>
        <div class="tl-desc">Share your design reference, target TOG, fabric preference, quantity, and delivery target.</div>
      </li>
      <li>
        <div class="tl-dot"></div>
        <div class="tl-label">Day 1–2</div>
        <div class="tl-title">Receive Quotation</div>
        <div class="tl-desc">Itemized FOB price, fabric options, MOQ, and sample fee (deducted from bulk order).</div>
      </li>
      <li>
        <div class="tl-dot"></div>
        <div class="tl-label">Day 3–25</div>
        <div class="tl-title">Sample Development</div>
        <div class="tl-desc">Pre-production sample made and shipped to you for approval.</div>
      </li>
      <li>
        <div class="tl-dot"></div>
        <div class="tl-label">Day 26–80</div>
        <div class="tl-title">Bulk Production</div>
        <div class="tl-desc">Production begins after sample sign-off. AQL inspection, then shipment.</div>
      </li>
    </ul>
  </section>

  <div class="cta-block">
    <h2>Start Your OEM Baby Sleeping Bag Project</h2>
    <p>Tell us your design, quantity, and target price. We'll send back a quotation within 24 hours.</p>
    <a href="mailto:quaner1234@gmail.com?subject=OEM Baby Sleeping Bag Inquiry" class="cta-email">
      quaner1234@gmail.com
    </a>
  </div>

  <footer>
    <p>© {new Date().getFullYear()} Taian Lianchuang Textile Co., Ltd. &nbsp;·&nbsp; <a href="/">lianchuangbaby.com</a></p>
  </footer>

</body>
</html>
