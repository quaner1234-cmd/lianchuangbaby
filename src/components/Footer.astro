      </div>
    </div>

    <div class="footer-col">
      <div class="footer-heading">Products</div>
      <a href="/products/tog-05">TOG 0.5 Summer Bag</a>
      <a href="/products/tog-10">TOG 1.0 All-Season</a>
      <a href="/products/tog-25">TOG 2.5 Winter Bag</a>
      <a href="/products/tog-35">TOG 3.5 Cold Climate</a>
    </div>

    <div class="footer-col">
      <div class="footer-heading">Services</div>
      <a href="/#oem">OEM / ODM</a>
      <a href="/#materials">Material Options</a>
      <a href="/#certifications">Certifications</a>
      <a href="/blog">Industry Blog</a>
    </div>

    <div class="footer-col">
      <div class="footer-heading">Contact</div>
      <a href="https://wa.me/8618265381705">WhatsApp: +86 182 6538 1705</a>
      <a href="https://wa.me/8618265381705">WeChat: +86 182 6538 1705</a>
      <a href="/#contact">Send an Inquiry</a>
